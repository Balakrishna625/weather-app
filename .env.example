# Weather App Configuration
# Copy this file to .env and set your actual values

# OpenWeatherMap API Configuration
# Get your free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=YOUR_ACTUAL_API_KEY_HERE

# Application Configuration (optional - defaults will be used if not set)
DEFAULT_CITY=London
API_ENDPOINT=http://api.openweathermap.org/data/2.5/weather
CITIES_CONFIG={"london":"London,UK","tokyo":"Tokyo,JP","newyork":"New York,US","sydney":"Sydney,AU","paris":"Paris,FR"}

# Development Configuration
PORT=3000
NODE_ENV=development

# Optional Admin Password for demo endpoints
ADMIN_PASSWORD=admin123